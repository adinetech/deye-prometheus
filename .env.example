# ---------------------------------------------------
# Deye Inverter — Connection Settings
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# ---------------------------------------------------

# IP address of the Solarman Wi-Fi data logger
INVERTER_IP=192.168.1.100

# Serial number printed on the Wi-Fi data logger (NOT the inverter serial)
INVERTER_SERIAL=1234567890

# Modbus TCP port (almost always 8899)
INVERTER_PORT=8899

# Modbus slave ID of the inverter (almost always 1)
INVERTER_MB_SLAVE_ID=1

# ---------------------------------------------------
# Exporter Settings
# ---------------------------------------------------

# Port to expose Prometheus metrics on
EXPORTER_PORT=9105

POLL_INTERVAL=10
